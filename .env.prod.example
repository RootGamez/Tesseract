# ─────────────────────────────────────────────────────────────────────────────
# Tesseract — Variables de entorno de PRODUCCIÓN (plantilla)
# Copia a .env.prod y rellena con TUS valores reales/secretos:
#     cp .env.prod.example .env.prod
# .env.prod está en .gitignore y NO debe comitearse jamás.
# Sustituye "tu-dominio.com" por tu dominio real en .env.prod (no aquí).
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,web,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
SECURE_SSL_REDIRECT=True

# ── Frontend (horneadas en el build de Vite) ──────────────────────────────────
VITE_API_URL=https://tu-dominio.com
VITE_WS_URL=wss://tu-dominio.com/ws
FRONTEND_URL=https://tu-dominio.com

# ── Red externa de Nginx Proxy Manager ────────────────────────────────────────
# Nombre de la red docker que comparte NPM con esta app (para que NPM enrute a
# los servicios por nombre). Créala: docker network create npm_proxy
PROXY_NETWORK=npm_proxy

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=tesseract
POSTGRES_PASSWORD=cambia-esto-password-fuerte-db
POSTGRES_DB=tesseract
DB_HOST=db
DB_PORT=5432
DB_NAME=tesseract
DB_USER=tesseract
DB_PASSWORD=cambia-esto-password-fuerte-db

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Almacenamiento: MinIO (S3-compatible) ─────────────────────────────────────
# USE_S3=False → usa el MinIO del compose (recomendado en el VPS).
# USE_S3=True  → usa AWS S3 real (rellena las AWS_* de abajo en su lugar).
USE_S3=False
# Credenciales internas de MinIO (server + cliente boto3 deben coincidir).
MINIO_ROOT_USER=cambia-esto-usuario-minio
MINIO_ROOT_PASSWORD=cambia-esto-password-fuerte-minio
MINIO_ACCESS_KEY=cambia-esto-usuario-minio
MINIO_SECRET_KEY=cambia-esto-password-fuerte-minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=tesseract
MINIO_USE_SSL=False
# URL pública que el NAVEGADOR usa para descargar las imágenes presignadas.
MINIO_PUBLIC_URL=https://s3.tu-dominio.com
PRESIGNED_URL_TTL_SECONDS=86400

# ── AWS S3 (sólo si USE_S3=True) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_CLOUDFRONT_DOMAIN=

# ── OAuth2 (Google) ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI (IA copilot) ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email (Anymail/SendGrid; opcional) ────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@tu-dominio.com
SENDGRID_API_KEY=

# ── Observabilidad (Sentry; opcional) ─────────────────────────────────────────
SENTRY_DSN=
